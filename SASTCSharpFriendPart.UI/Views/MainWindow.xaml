<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SASTCSharpFriendPart_UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SASTCSharpFriendPart_UI.Views"
    xmlns:vm="using:SASTCSharpFriendPart_UI.ViewModels"
    Title="Friend Management System">
    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="40"
              VerticalAlignment="Top">
            <StackPanel
                x:Name="TitleStackPanel"
                Margin="16,10,0,0"
                Orientation="Horizontal"
                Spacing="8">
                <Image
                    Width="16"
                    Height="16"
                    VerticalAlignment="Center"
                    Source="ms-appx:///Assets/StoreLogo.scale-200.png"/>
                <TextBlock
                    x:Name="TitleTextBlock"
                    Margin="0,0,0,2"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="Friend Management System"/>
            </StackPanel>
        </Grid>

        <!-- 内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧面板 -->
            <Border Grid.Column="0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="5">
                        <Button x:Name="WelcomeButton"
                                Content="🎉 欢迎！"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="20,15"
                                Margin="0,4"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="4"
                                Command="{x:Bind ViewModel.NavigateCommand}"
                                CommandParameter="WelcomePage"/>
                        <Button x:Name="FriendButton"
                                Content="🦊 动物朋友"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="20,15"
                                Margin="0,4"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="4"
                                Command="{x:Bind ViewModel.NavigateCommand}"
                                CommandParameter="FriendPage"/>
                    </StackPanel>

                    <Button x:Name="SettingsButton"
                            Content="⚙️ Settings"
                            Grid.Row="2"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="20,15"
                            Margin="5,5,5,10"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="4"
                            Command="{x:Bind ViewModel.NavigateCommand}"
                            CommandParameter="SettingsPage"/>
                </Grid>
            </Border>

            <!-- 内容框架 -->
            <Frame x:Name="RootFrame"
                   Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>
