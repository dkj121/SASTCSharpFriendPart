<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SASTCSharpFriendPart_UI.Views.MoreInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SASTCSharpFriendPart_UI.ViewModels"
    Background="Transparent">

    <Grid MaxWidth="1200"
          Margin="36,40">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Reference section -->
                <StackPanel Margin="0,32,0,24">
                    <TextBlock
                        Text="参考资料"
                        FontSize="24"
                        FontWeight="Light"
                        Margin="0,0,0,24"/>

                    <TextBlock
                        Margin="0,0,0,8"
                        Foreground="DodgerBlue"
                        FontSize="15"
                        TextDecorations="Underline"
                        IsTapEnabled="True"
                        Tapped="Link_Tapped"
                        Tag="https://docs.avaloniaui.net/docs/Welcome">
                        Avalonia官方文档
                    </TextBlock>

                    <TextBlock
                        Margin="0,0,0,8"
                        Foreground="DodgerBlue"
                        FontSize="15"
                        TextDecorations="Underline"
                        IsTapEnabled="True"
                        Tapped="Link_Tapped"
                        Tag="https://njupt-sast.feishu.cn/wiki/JpR6weWPriWfiekYfFPcTl7Rnog">
                        免试题指南
                    </TextBlock>

                    <!-- Contact info -->
                    <TextBlock
                        Text="C#组No.35全体成员联系方式"
                        FontSize="24"
                        FontWeight="Light"
                        Margin="0,32,0,24"/>

                    <StackPanel Margin="0,0,0,8">
                        <TextBlock>
                            <Run Text="dkj"/>
                            <Run Text="QQ: 2726073422"
                                 FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="记得加入C#组招新群哦🥰"/>
                    </StackPanel>
                </StackPanel>

                <!-- QR code images -->
                <StackPanel Orientation="Horizontal">
                    <Image
                        Source="Assets/dotnet.png"
                        HorizontalAlignment="Left"
                        Margin="10,50"
                        Height="400"
                        Width="300"/>
                    <Image
                        Source="Assets/qrcode_1784464242477.jpg"
                        HorizontalAlignment="Left"
                        Margin="10,50"
                        Height="600"
                        Width="450"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
