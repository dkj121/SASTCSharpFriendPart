<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SASTCSharpFriendPart_UI.Views.FriendPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SASTCSharpFriendPart_UI.ViewModels"
    Background="Transparent">

    <Page.Resources>
        <Storyboard x:Name="EntranceAnimation">
            <DoubleAnimation
                Storyboard.TargetName="MainBorder"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.6"/>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Border
            x:Name="MainBorder"
            CornerRadius="8"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Margin="50"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch"
            MaxWidth="1000"
            MaxHeight="800"
            Opacity="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left panel -->
                <Grid Grid.Column="0"
                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border
                        BorderThickness="0,1,0,0"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        VerticalAlignment="Stretch"
                        Padding="24,0,24,52">
                        <StackPanel>
                            <TextBlock
                                Text="My Friends"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="12,40,12,36"/>
                            <TextBox
                                PlaceholderText="Friend Name"
                                HorizontalAlignment="Stretch"
                                Margin="12,6,24,6"
                                IsReadOnly="{x:Bind FriendPage.InvertBool(ViewModel.IsEditing), Mode=OneWay}"
                                Text="{x:Bind ViewModel.FriendName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox
                                PlaceholderText="Friend Description"
                                HorizontalAlignment="Stretch"
                                Margin="12,6,24,6"
                                IsReadOnly="{x:Bind FriendPage.InvertBool(ViewModel.IsEditing), Mode=OneWay}"
                                Text="{x:Bind ViewModel.FriendDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Border>

                    <Border Padding="24"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Background="Transparent">
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button
                                VerticalAlignment="Top"
                                Margin="6,6,6,6"
                                Width="80"
                                HorizontalAlignment="Left"
                                Visibility="{x:Bind FriendPage.EditButtonVisible(ViewModel.SelectedFriendName, ViewModel.IsEditing), Mode=OneWay}"
                                Command="{x:Bind ViewModel.EditCommand}"
                                Content="    Edit"/>
                            <ComboBox
                                Grid.Column="1"
                                Margin="6,6,6,6"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.FriendNames, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedFriendName, Mode=TwoWay}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Right panel: image -->
                <Image
                    Stretch="UniformToFill"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Source="{x:Bind FriendPage.GetImageSource(ViewModel.ImagePath), Mode=OneWay}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
