<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SASTCSharpFriendPart_UI.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SASTCSharpFriendPart_UI.Controls"
    xmlns:vm="using:SASTCSharpFriendPart_UI.ViewModels"
    Background="Transparent">

    <Page.Resources>
        <!-- 导入动画 -->
        <Storyboard x:Name="HeroAnimation">
            <DoubleAnimation
                Storyboard.TargetName="HeroImage"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:1.5"/>
            <DoubleAnimation
                Storyboard.TargetName="HeroImageTranslate"
                Storyboard.TargetProperty="X"
                From="52.8"
                To="0"
                Duration="0:0:1.5"/>
            <DoubleAnimation
                Storyboard.TargetName="HeroImageTranslate"
                Storyboard.TargetProperty="Y"
                From="488"
                To="0"
                Duration="0:0:1.5"/>
        </Storyboard>

        <Storyboard x:Name="MainTextAnimation">
            <DoubleAnimation
                Storyboard.TargetName="MainText"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.8"/>
            <DoubleAnimation
                Storyboard.TargetName="MainTextTranslate"
                Storyboard.TargetProperty="X"
                From="-1.6"
                To="0"
                Duration="0:0:0.8"/>
            <DoubleAnimation
                Storyboard.TargetName="MainTextTranslate"
                Storyboard.TargetProperty="Y"
                From="72"
                To="0"
                Duration="0:0:0.8"/>
        </Storyboard>

        <Storyboard x:Name="LogoAnimation">
            <DoubleAnimation
                Storyboard.TargetName="Logo"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                BeginTime="0:0:0.3"
                Duration="0:0:1.1">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="SubTextAnimation">
            <DoubleAnimation
                Storyboard.TargetName="SubText"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                BeginTime="0:0:0.2"
                Duration="0:0:0.7"/>
            <DoubleAnimation
                Storyboard.TargetName="SubTextScale"
                Storyboard.TargetProperty="ScaleX"
                From="0.98"
                To="1"
                BeginTime="0:0:0.2"
                Duration="0:0:0.7"/>
            <DoubleAnimation
                Storyboard.TargetName="SubTextScale"
                Storyboard.TargetProperty="ScaleY"
                From="0.95"
                To="1"
                BeginTime="0:0:0.2"
                Duration="0:0:0.7"/>
        </Storyboard>

        <Storyboard x:Name="HelpButtonAnimation">
            <DoubleAnimation
                Storyboard.TargetName="HelpButton"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                BeginTime="0:0:0.9"
                Duration="0:0:0.6"/>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <!-- 背景图片 -->
        <Image
            x:Name="HeroImage"
            Width="923"
            Height="839"
            Margin="0,0,-130,-246"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Source="ms-appx:///Assets/home-hero.png"
            Opacity="0">
            <Image.RenderTransform>
                <TranslateTransform x:Name="HeroImageTranslate"
                                    X="52.8"
                                    Y="488"/>
            </Image.RenderTransform>
        </Image>

        <StackPanel
            MaxWidth="1300"
            MaxHeight="700"
            MinWidth="600"
            MinHeight="400"
            Margin="10"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center">

            <!-- 主标题 -->
            <TextBlock
                x:Name="MainText"
                Width="632"
                Margin="64,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="48"
                LineHeight="72"
                Opacity="0">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="MainTextTranslate"
                                        X="-1.6"
                                        Y="72"/>
                </TextBlock.RenderTransform>
                <Run Text="Welcome to SAST"/>
                <LineBreak/>
                <Run FontWeight="SemiBold"
                     Text="      Group"/>
                <Run Text=" !"/>
            </TextBlock>

            <!-- C# logo -->
            <Image
                x:Name="Logo"
                Width="80"
                Height="80"
                Margin="56,-76,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="ms-appx:///Assets/C_Sharp_Logo_2023.svg.png"
                Opacity="0"/>

            <!-- 副标题 -->
            <TextBlock
                x:Name="SubText"
                Width="470"
                Margin="64,24,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontFamily="Microsoft YaHei UI"
                FontSize="24"
                LineHeight="32"
                TextWrapping="Wrap"
                Opacity="0">
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="SubTextScale"
                                    ScaleX="0.98"
                                    ScaleY="0.95"/>
                </TextBlock.RenderTransform>
                <Run Text="恭喜你迈出了你的第一步！"/>
                <LineBreak/>
                <Run Text="如果你成功看到此界面，"/>
                <LineBreak/>
                <Run Text="你已经"/>
                <Run FontWeight="Bold"
                     Text="超越90%的人"/>
                <Run Foreground="Gray"
                     Text="*"/>
                <Run Text="了！"/>
                <LineBreak/>
                <Run Text="请继续努力！"/>
                <LineBreak/>
                <Run FontSize="12"
                     Foreground="Gray"
                     Text="*: 数据来源于22级C#组长"/>
            </TextBlock>

            <!-- 帮助按钮 -->
            <controls:LargeButton
                x:Name="HelpButton"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Margin="64,80,0,0"
                Click="HelpButton_Click"
                MainTitle="需要帮助？"
                SubTitle="戳我查看获取帮助的途径"
                Opacity="0">
                <controls:LargeButton.Icon>
                    <TextBlock
                        Text="⇨"
                        FontSize="48"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>
                </controls:LargeButton.Icon>
            </controls:LargeButton>
        </StackPanel>
    </Grid>
</Page>
