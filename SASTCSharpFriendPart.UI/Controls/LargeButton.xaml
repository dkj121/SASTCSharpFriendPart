<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SASTCSharpFriendPart_UI.Controls.LargeButton"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="8">
        <Button
            x:Name="MainButton"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Click="MainButton_Click"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <Border Padding="24,20">
                <Grid VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ContentPresenter
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Content="{Binding Icon, ElementName=Root}"/>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="6"
                        Margin="4,0,0,0">
                        <TextBlock
                            x:Name="TitleText"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text="{Binding MainTitle, ElementName=Root}"/>
                        <TextBlock
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{Binding SubTitle, ElementName=Root}"
                            Opacity="0.85"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Button>
    </Border>
</UserControl>
